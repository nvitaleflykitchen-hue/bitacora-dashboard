# Variables de entorno requeridas — bitacora-dashboard
# Copiar este archivo a .env.local y completar con los valores reales.
# Detalle completo en docs/SETUP.md.

# URL del proyecto Supabase. Dashboard de Supabase → Project Settings → API → Project URL.
# Proyecto correcto para este repo: mixyhfdlzjarvszinytk (NO usar hmyzuuujyurvyuusvyzp / "Octopus Coquinaria", es otro cliente — ver AGENTS.md §0.1).
VITE_SUPABASE_URL=https://mixyhfdlzjarvszinytk.supabase.co

# Clave pública (anon key) del mismo proyecto. Dashboard de Supabase → Project Settings → API → Project API keys → anon/public.
# Es la clave de cliente, no la service_role key — nunca poner la service_role key en una variable VITE_* (queda embebida en el bundle del frontend, visible para cualquiera).
VITE_SUPABASE_ANON_KEY=

# Clave pública Web Push. Generar el par con: node scripts/generate-vapid.mjs
# Esta clave pública se configura también en Vercel. La clave privada NUNCA usa prefijo VITE_.
VITE_VAPID_PUBLIC_KEY=

# ADVERTENCIA: no hay un proyecto Supabase de staging/desarrollo separado.
# Con estas dos variables, npm run dev apunta directo a la base de datos de producción real de Fly Kitchen.
